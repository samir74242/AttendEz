<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>AttendEz</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>com.aistudio.attendez</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>AttendEz</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	
	<!-- iOS equivalent of RECORD_AUDIO permission -->
	<key>NSMicrophoneUsageDescription</key>
	<string>AttendEz needs access to the microphone to allow audio note captures and record lecture annotations during check-ins.</string>
	
	<!-- iOS equivalent of CAMERA permission for barcode or biometrics if expanded -->
	<key>NSCameraUsageDescription</key>
	<string>AttendEz requires camera access to scan physical schedules and timetable sheets for instant text importing.</string>
	
	<!-- iOS Biometric support (FaceID) -->
	<key>NSFaceIDUsageDescription</key>
	<string>AttendEz uses Face ID authentication to secure your daily student attendance logs and authorize local backups.</string>

	<!-- Background Modes to mirror Android Broadcasts & WorkManager -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
		<string>remote-notification</string>
	</array>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
