# CocoaPods dependency specification for AttendEz iOS Application
platform :ios, '15.0'

use_frameworks!

target 'iosApp' do
  # Firebase SDK components matching Android features
  pod 'FirebaseCore', '~> 10.24.0'
  pod 'FirebaseAuth', '~> 10.24.0'
  pod 'FirebaseDatabase', '~> 10.24.0'
  pod 'FirebaseMessaging', '~> 10.24.0'
  
  # Swift equivalent for Firebase AI/Vertex API (Gemini integrations)
  pod 'FirebaseVertexAI', '~> 10.24.0'

  # Test utilities
  target 'iosAppTests' do
    inherit! :search_paths
  end
end
